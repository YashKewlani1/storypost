    "dev:frontend": "cd frontend && npm run dev"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "multer": "^2.1.1",
    "openai": "^6.38.0"
  },
  "engines": {
    "node": ">=20"
  }
}
